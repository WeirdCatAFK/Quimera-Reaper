# Puppeteer Configuration
# Path to your chrome/msedge/brave executable
# Example: C:\Program Files\Google\Chrome\Application\chrome.exe
BROWSER_EXECUTABLE_PATH=
# Path to store browser user data for session persistence
USER_DATA_DIR=./user_data

# MusicBee Configuration
# Root directory where songs will be saved
MUSIC_OUTPUT_DIR=./music_library
# Folder structure template: Artist/Album/Title.mp3
FOLDER_STRUCTURE="{artist}/{album}/{title}.mp3"

# Recording Settings
# Bitrate in kbps (e.g., 128, 192, 256, 320)
AUDIO_BITRATE=192
# Max songs to sync per session (to look natural)
MAX_SONGS_PER_SESSION=20
# Min delay between songs in seconds
MIN_DELAY_SECONDS=30
# Max delay between songs in seconds
MAX_DELAY_SECONDS=120
